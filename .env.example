# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SUPABASE_STORAGE_BUCKET=receipts

# App Configuration
VITE_APP_NAME=BeforeCharge
VITE_APP_URL=http://localhost:5173
VITE_CREATE_DUMMY_DATA=false

# Feature flags (optional)
VITE_ENABLE_GOOGLE_AUTH=true
VITE_ENABLE_EMAIL_REMINDERS=false
VITE_ENABLE_RECEIPT_UPLOAD=true
VITE_ENABLE_ANALYTICS=true

# Currency defaults (optional)
VITE_DEFAULT_CURRENCY=USD
VITE_SUPPORTED_CURRENCIES=USD,EUR,GBP,INR,AED