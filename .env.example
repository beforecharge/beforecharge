# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SUPABASE_STORAGE_BUCKET=receipts

# Supabase Service Role Key (for test user creation and admin operations)
# Get this from: Supabase Dashboard > Settings > API > service_role key
# WARNING: Keep this secret! Never commit to version control or expose to client
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# App Configuration
VITE_APP_NAME=BeforeCharge
VITE_APP_URL=http://localhost:3000
VITE_CREATE_DUMMY_DATA=false

# Feature flags (optional)
VITE_ENABLE_GOOGLE_AUTH=true
VITE_ENABLE_EMAIL_REMINDERS=true
VITE_ENABLE_RECEIPT_UPLOAD=true
VITE_ENABLE_ANALYTICS=true

# Email Service Configuration (for Edge Functions)
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key

# Currency defaults (optional)
VITE_DEFAULT_CURRENCY=USD
VITE_SUPPORTED_CURRENCIES=USD,EUR,GBP,INR,AED